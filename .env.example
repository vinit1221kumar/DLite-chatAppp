# ============================================================================
# D-LITE - Example Environment Configuration
# ============================================================================
# Copy this file to .env and update values for your environment.
# DO NOT commit real secrets to version control.
# ============================================================================

NODE_ENV=development

# ----------------------------------------------------------------------------
# Ports (4-service architecture)
# ----------------------------------------------------------------------------
CORE_PORT=4000
REALTIME_PORT=4003

# ----------------------------------------------------------------------------
# Supabase (backend services)
# ----------------------------------------------------------------------------
SUPABASE_URL=https://your-project-id.supabase.co
SUPABASE_ANON_KEY=your-supabase-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key

# ----------------------------------------------------------------------------
# Worker backup (optional)
# ----------------------------------------------------------------------------
# Enable HTTP endpoints for Render "Web Service" worker deployments.
WORKER_HTTP_ENABLED=0
# PORT is typically injected by platforms like Render/Railway. Keep as fallback.
WORKER_PORT=10000
BACKUP_INTERVAL_SECONDS=300
BACKUP_BATCH_SIZE=500
BACKUP_OUTPUT_DIR=/data
BACKUP_STATE_FILE=/data/state.json

# ----------------------------------------------------------------------------
# Cloudinary (media service / optional)
# ----------------------------------------------------------------------------
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
CLOUDINARY_FOLDER=d-lite/media
MAX_FILE_SIZE_MB=50

# ----------------------------------------------------------------------------
# CORS (core-backend)
# ----------------------------------------------------------------------------
CORS_ORIGINS=http://localhost:3000

# ----------------------------------------------------------------------------
# Local auth fallback consistency (optional)
# ----------------------------------------------------------------------------
AUTH_JWT_SECRET=
JWT_SECRET=

# ----------------------------------------------------------------------------
# Frontend public configuration (Next.js)
# ----------------------------------------------------------------------------
NEXT_PUBLIC_API_BASE_URL=http://localhost:4000
NEXT_PUBLIC_CHAT_SOCKET_URL=http://localhost:4003
NEXT_PUBLIC_CALL_SOCKET_URL=http://localhost:4003

# Supabase for frontend (required for Google sign-in callback/session)
NEXT_PUBLIC_SUPABASE_URL=https://your-project-id.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-supabase-anon-key

# WebRTC ICE servers (stun/turn) for stable calling/video.
# Recommended in production: add TURN (coturn) in addition to Google STUN.
NEXT_PUBLIC_ICE_SERVERS_JSON=[{"urls":["stun:stun.l.google.com:19302"]}]

