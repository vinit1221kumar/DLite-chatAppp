# ============================================================================
# D-Lite Microservices Stack - Environment Configuration
# ============================================================================
# Copy this file to .env and update values for your environment
# DO NOT commit .env with real secrets to version control
# ============================================================================

# Node Environment (development, production, staging)
NODE_ENV=development

# Service Port (set per service when running locally)
PORT=4000
GATEWAY_PORT=4000
AUTH_PORT=4001
CHAT_PORT=4002
CALL_PORT=4003
MEDIA_PORT=4004

# ============================================================================
# SECURITY & AUTH
# ============================================================================

# JWT Secret for signing authentication tokens
# Generate: openssl rand -hex 32
JWT_SECRET=your-super-secret-jwt-key-change-in-production

# Supabase Auth
SUPABASE_URL=https://your-project-id.supabase.co
SUPABASE_ANON_KEY=your-supabase-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key

# CORS Origins (comma-separated)
CORS_ORIGINS=http://localhost:5173,http://localhost:3000,http://localhost:8080

# ============================================================================
# REDIS
# ============================================================================

# Redis Connection URL (Docker: redis://redis:6379)
REDIS_URL=redis://redis:6379

# ============================================================================
# DATABASE
# ============================================================================

# MongoDB Connection URL
# Docker: mongodb://mongo:27017/d-lite-auth
# For local development, ensure MongoDB is running
DATABASE_URL=mongodb://localhost:27017/d-lite-auth
MONGODB_URI=mongodb://localhost:27017
MONGODB_DB_NAME=d_lite_backup
MONGODB_COLLECTION_NAME=message_backups

# ============================================================================
# RATE LIMITING (Call Service)
# ============================================================================

# Rate limit window in milliseconds (default: 10000 = 10 seconds)
RATE_LIMIT_WINDOW_MS=10000

# Maximum messages per user per event within the window (default: 60)
RATE_LIMIT_MAX_MESSAGES=60

# Call session TTL in seconds (default: 3600 = 1 hour)
CALL_SESSION_TTL_SECONDS=3600

# Backup worker schedule (every 5 minutes by default)
BACKUP_CRON_SCHEDULE=*/5 * * * *
BACKUP_BATCH_SIZE=500

# ============================================================================
# LOGGING
# ============================================================================

# Log level: error, warn, info, debug, trace
LOG_LEVEL=info

# ============================================================================
# FRONTEND
# ============================================================================

# API Base URL (for frontend requests to backend)
VITE_API_BASE_URL=http://localhost:4000

# Socket Gateway URL (for real-time WebSocket connections)
VITE_SOCKET_URL=http://localhost:4000

# Service-specific URLs (if frontend needs direct access)
VITE_CALL_SERVICE_URL=http://localhost:4003
VITE_MEDIA_SERVICE_URL=http://localhost:4004

# ============================================================================
# INTERNAL SERVICE URLS (Docker network discovery)
# ============================================================================

# Used by services to communicate with each other inside Docker network
AUTH_SERVICE_URL=http://localhost:4001
CHAT_SERVICE_URL=http://localhost:4002
CALL_SERVICE_URL=http://localhost:4003
MEDIA_SERVICE_URL=http://localhost:4004
GROUP_CHAT_SERVICE_URL=http://localhost:4002

# Gateway-specific CORS setting
GATEWAY_CORS_ORIGIN=*

# ============================================================================
# MEDIA SERVICE (Cloudinary Integration)
# ============================================================================

# Cloudinary Configuration
CLOUDINARY_CLOUD_NAME=your-cloudinary-cloud-name
CLOUDINARY_API_KEY=your-cloudinary-api-key
CLOUDINARY_API_SECRET=your-cloudinary-api-secret

# Maximum file size for uploads in MB
MAX_FILE_SIZE_MB=50

# ============================================================================
# OPTIONAL: WEBRTC & STUN/TURN
# ============================================================================

# STUN servers for NAT traversal (comma-separated)
STUN_SERVERS=stun:stun.l.google.com:19302,stun:stun1.l.google.com:19302

# TURN server configuration (if using TURN)
TURN_SERVER=
TURN_USERNAME=
TURN_PASSWORD=

# ============================================================================
# OPTIONAL: MONITORING & OBSERVABILITY
# ============================================================================

# Sentry DSN for error tracking
SENTRY_DSN=

# APM Service URL
APM_SERVICE_URL=

# ============================================================================
# DEPLOYMENT-SPECIFIC (Docker/Kubernetes)
# ============================================================================

# Docker registry for image pulls
DOCKER_REGISTRY=docker.io

# Image tag version
IMAGE_TAG=latest
