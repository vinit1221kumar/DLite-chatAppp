# ============================================================================
# D-LITE - Example Environment Configuration
# ============================================================================
# Copy this file to .env and update values for your environment.
# DO NOT commit real secrets to version control.
# ============================================================================

NODE_ENV=development

# ----------------------------------------------------------------------------
# Ports
# ----------------------------------------------------------------------------
GATEWAY_PORT=4000
AUTH_PORT=4001
CHAT_PORT=4002
CALL_PORT=4003
MEDIA_PORT=4004

# ----------------------------------------------------------------------------
# Supabase (backend services)
# ----------------------------------------------------------------------------
SUPABASE_URL=https://xxxx.supabase.co
SUPABASE_ANON_KEY=eyJ...
NEXT_PUBLIC_SUPABASE_URL=https://xxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...
SUPABASE_SERVICE_ROLE_KEY=eyJ...
# ----------------------------------------------------------------------------
# MongoDB (backup worker / optional)
# ----------------------------------------------------------------------------
MONGODB_URI=mongodb://mongo:27017
MONGODB_DB_NAME=d_lite_backup
MONGODB_COLLECTION_NAME=message_backups

# ----------------------------------------------------------------------------
# Cloudinary (media service / optional)
# ----------------------------------------------------------------------------
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
CLOUDINARY_FOLDER=d-lite/media
MAX_FILE_SIZE_MB=50

# ----------------------------------------------------------------------------
# CORS
# ----------------------------------------------------------------------------
CORS_ORIGINS=http://localhost:3000
GATEWAY_CORS_ORIGIN=*

# ----------------------------------------------------------------------------
# Call service
# ----------------------------------------------------------------------------
JWT_SECRET=replace-with-strong-secret
REDIS_URL=redis://redis:6379
RATE_LIMIT_WINDOW_MS=10000
RATE_LIMIT_MAX_MESSAGES=60
CALL_SESSION_TTL_SECONDS=3600

# ----------------------------------------------------------------------------
# Frontend public configuration (Next.js)
# ----------------------------------------------------------------------------
NEXT_PUBLIC_API_BASE_URL=http://localhost:4000
NEXT_PUBLIC_CHAT_SOCKET_URL=http://localhost:4002
NEXT_PUBLIC_CALL_SOCKET_URL=http://localhost:4003

# Supabase for frontend (required for Google sign-in callback/session)
NEXT_PUBLIC_SUPABASE_URL=https://your-project-id.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-supabase-anon-key

# WebRTC ICE servers (stun/turn) for stable calling/video.
# Recommended in production: add TURN (coturn) in addition to Google STUN.
NEXT_PUBLIC_ICE_SERVERS_JSON=[{"urls":["stun:stun.l.google.com:19302"]}]

