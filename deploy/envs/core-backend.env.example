# core-backend (FastAPI REST)

NODE_ENV=production
PORT=4000

# CORS (comma-separated)
CORS_ORIGINS=https://app.example.com

# Supabase
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_ANON_KEY=your-supabase-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key

# Local auth fallback (recommended)
AUTH_JWT_SECRET=replace-with-strong-secret
# (legacy alias supported)
JWT_SECRET=replace-with-strong-secret

# Optional: Cloudinary media uploads
# CLOUDINARY_CLOUD_NAME=
# CLOUDINARY_API_KEY=
# CLOUDINARY_API_SECRET=
# CLOUDINARY_FOLDER=d-lite/media
# MAX_FILE_SIZE_MB=50

# Optional: force local auth mode
# AUTH_MODE=local

# Optional: persistence for local auth fallback users
# LOCAL_AUTH_PERSISTENCE=file
# LOCAL_AUTH_PERSISTENCE=supabase
# LOCAL_AUTH_PERSISTENCE=both

# Optional: Uvicorn tuning
# UVICORN_WORKERS=2
# UVICORN_LOG_LEVEL=info

